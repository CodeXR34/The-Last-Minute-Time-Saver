rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default to enforce least privilege
    match /{document=**} {
      allow read, write: if false;
    }

    // Tasks: Authenticated users can read and write only their own tasks
    match /tasks/{taskId} {
      // For create, check the incoming data's userId
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // For read/update/delete, check the existing document's userId
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users: Authenticated users can read and update only their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // UserSettings: Extensions of user profile
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // AI Decision Logs: Immutable history of autonomous actions
    match /decisionLogs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
